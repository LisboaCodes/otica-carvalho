# Copie para .env e preencha. Nunca versione o .env — ele esta no .gitignore.

# ------------------------------- banco de dados -------------------------------
# Postgres local ou do Coolify (rede interna do Docker, sem TLS):
DATABASE_URL=postgres://otica:senha@localhost:5432/otica_garantias

# TLS: "disable" (padrao, rede interna) | "require" (Postgres gerenciado na internet)
DATABASE_SSL=disable

# -------------------------------- aplicacao ----------------------------------
PORT=3000

# development | production. Em producao (HTTPS) o cookie de sessao vira Secure.
NODE_ENV=development

# Assina o cookie de sessao do admin. Gere um novo com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# ---------------------- primeiro administrador (opcional) ---------------------
# Usado apenas quando a tabela de admins esta vazia — util no deploy em container.
# Localmente prefira: npm run admin:criar -- usuario "Nome Completo" Senha123
ADMIN_USUARIO=
ADMIN_NOME=
ADMIN_SENHA=
